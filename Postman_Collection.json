{
	"info": {
		"name": "Intern Task APIs",
		"description": "Backend API collection for the Intern Task assignment.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"password123\",\n    \"role\": \"user\"\n}"
						},
						"url": { "raw": "http://localhost:5000/api/v1/auth/register", "protocol": "http", "host": [ "localhost" ], "port": "5000", "path": [ "api", "v1", "auth", "register" ] }
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"password123\"\n}"
						},
						"url": { "raw": "http://localhost:5000/api/v1/auth/login", "protocol": "http", "host": [ "localhost" ], "port": "5000", "path": [ "api", "v1", "auth", "login" ] }
					}
				}
			]
		},
		{
			"name": "Tasks",
			"item": [
				{
					"name": "Create Task",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My First Task\",\n    \"description\": \"This is a test task\"\n}"
						},
						"url": { "raw": "http://localhost:5000/api/v1/tasks", "protocol": "http", "host": [ "localhost" ], "port": "5000", "path": [ "api", "v1", "tasks" ] }
					}
				},
				{
					"name": "Get All Tasks",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
						],
						"url": { "raw": "http://localhost:5000/api/v1/tasks", "protocol": "http", "host": [ "localhost" ], "port": "5000", "path": [ "api", "v1", "tasks" ] }
					}
				}
			]
		}
	]
}